[
  {"id":1,"metric":"Total revenue","category":"Finance","description":"total sales before expenses","formula":"price × units sold","source":"Accounting/CRM"},
  {"id":2,"metric":"Revenue growth rate","category":"Finance","description":"percentage change vs. prior period","formula":"(revenue_t - revenue_t-1)/revenue_t-1","source":"Accounting"},
  {"id":3,"metric":"Gross profit margin","category":"Finance","description":"profit after COGS","formula":"(revenue - COGS)/revenue","source":"Accounting"},
  {"id":4,"metric":"Net profit margin","category":"Finance","description":"profit after all expenses","formula":"net income / revenue","source":"Accounting"},
  {"id":5,"metric":"Operating profit margin","category":"Finance","description":"profit from core operations","formula":"operating income / revenue","source":"Accounting"},
  {"id":6,"metric":"Contribution margin","category":"Finance","description":"contribution to fixed costs","formula":"(revenue - variable costs)/revenue","source":"Accounting"},
  {"id":7,"metric":"Average order value (AOV)","category":"Sales","description":"average revenue per transaction","formula":"total sales / number of orders","source":"CRM/Accounting"},
  {"id":8,"metric":"Average revenue per customer (ARPC)","category":"Sales","description":"revenue per customer","formula":"total revenue / number of customers","source":"CRM/Accounting"},
  {"id":9,"metric":"Sales by product/service","category":"Sales","description":"revenue composition by product","formula":"aggregated sales by SKU","source":"Accounting/CRM"},
  {"id":10,"metric":"Sales mix by channel/region","category":"Sales","description":"revenue by channel or location","formula":"aggregated sales by channel","source":"Accounting/CRM"},
  {"id":11,"metric":"Operating cash flow (OCF)","category":"Cash","description":"cash from core operations","formula":"net income + non-cash charges - Δworking capital","source":"Accounting"},
  {"id":12,"metric":"Free cash flow (FCF)","category":"Cash","description":"cash after capital expenditure","formula":"operating cash flow - capex","source":"Accounting"},
  {"id":13,"metric":"Cash runway","category":"Cash","description":"months of cash left","formula":"cash balance / monthly burn rate","source":"Accounting"},
  {"id":14,"metric":"Burn rate","category":"Cash","description":"monthly net cash loss","formula":"monthly expenses - monthly revenue","source":"Accounting"},
  {"id":15,"metric":"Working capital","category":"Cash","description":"liquidity for short-term obligations","formula":"current assets - current liabilities","source":"Accounting"},
  {"id":16,"metric":"Current ratio","category":"Liquidity","description":"ability to pay short-term bills","formula":"current assets / current liabilities","source":"Accounting"},
  {"id":17,"metric":"Quick ratio","category":"Liquidity","description":"immediate solvency","formula":"(cash + marketable securities + A/R) / current liabilities","source":"Accounting"},
  {"id":18,"metric":"Cash conversion cycle (CCC)","category":"Liquidity","description":"days cash tied up in operations","formula":"DSO + DIO - DPO","source":"Accounting"},
  {"id":19,"metric":"Accounts receivable aging","category":"Liquidity","description":"days customers take to pay","formula":"report grouping invoices by age","source":"Accounting"},
  {"id":20,"metric":"Accounts payable aging","category":"Liquidity","description":"days the company takes to pay suppliers","formula":"report grouping payables by age","source":"Accounting"},
  {"id":21,"metric":"Pipeline value","category":"Sales","description":"total value of open deals","formula":"sum of deal amounts in pipeline","source":"CRM"},
  {"id":22,"metric":"Pipeline coverage ratio","category":"Sales","description":"pipeline vs. quota","formula":"pipeline value / target quota","source":"CRM"},
  {"id":23,"metric":"Number of opportunities","category":"Sales","description":"active deals count","formula":"count of open deals","source":"CRM"},
  {"id":24,"metric":"Average deal size","category":"Sales","description":"mean value of deals","formula":"total deal value / number of deals","source":"CRM"},
  {"id":25,"metric":"Win rate (opportunity-to-win)","category":"Sales","description":"efficiency of sales process","formula":"(won opportunities / total opportunities) × 100","source":"CRM"},
  {"id":26,"metric":"Sales velocity","category":"Sales","description":"speed of revenue generation","formula":"(opportunities × average deal size × win rate) / sales cycle","source":"CRM"},
  {"id":27,"metric":"Average sales cycle length","category":"Sales","description":"days to close a deal","formula":"(Σ days from lead to close) / number of closed deals","source":"CRM"},
  {"id":28,"metric":"Lead conversion rate","category":"Sales","description":"leads turning into deals","formula":"deals / leads","source":"CRM"},
  {"id":29,"metric":"Lead response time","category":"Sales","description":"time to follow up on leads","formula":"average time from lead creation to first contact","source":"CRM"},
  {"id":30,"metric":"Funnel drop-off rate","category":"Sales","description":"percentage exiting each stage","formula":"leads exiting stage / leads entering stage","source":"CRM"},
  {"id":31,"metric":"Time in stage","category":"Sales","description":"average time deals spend in each pipeline stage","formula":"days in stage per deal","source":"CRM"},
  {"id":32,"metric":"Deal slippage rate","category":"Sales","description":"percentage of deals delayed to next period","formula":"slipped deals / total deals","source":"CRM"},
  {"id":33,"metric":"Lost deal reason distribution","category":"Sales","description":"breakdown of reasons for lost deals","formula":"count by reason codes","source":"CRM"},
  {"id":34,"metric":"Sales rep quota attainment","category":"Sales","description":"performance vs. target","formula":"rep revenue / rep quota","source":"CRM/HR"},
  {"id":35,"metric":"Forecast accuracy","category":"Sales","description":"accuracy of sales forecast","formula":"(actual revenue - forecast) / forecast","source":"CRM"},
  {"id":36,"metric":"Customer acquisition cost (CAC)","category":"Customer","description":"cost to acquire one customer","formula":"(sales + marketing costs) / new customers","source":"CRM/Marketing"},
  {"id":37,"metric":"Customer lifetime value (CLV/LTV)","category":"Customer","description":"total revenue from a customer","formula":"avg purchase value × purchase frequency × avg lifespan","source":"CRM/Accounting"},
  {"id":38,"metric":"LTV/CAC ratio","category":"Customer","description":"efficiency of acquisition","formula":"LTV / CAC","source":"CRM/Accounting"},
  {"id":39,"metric":"Retention rate","category":"Customer","description":"percentage of customers staying","formula":"((end customers - new customers)/start customers) × 100","source":"CRM"},
  {"id":40,"metric":"Churn rate","category":"Customer","description":"percentage of customers leaving","formula":"lost customers / starting customers","source":"CRM"},
  {"id":41,"metric":"Net revenue retention (NRR)","category":"Customer","description":"recurring revenue expansion","formula":"(current recurring revenue from existing customers / prior period) × 100","source":"CRM/Accounting"},
  {"id":42,"metric":"Repeat purchase rate","category":"Customer","description":"customers buying again","formula":"repeat customers / total customers","source":"CRM"},
  {"id":43,"metric":"Average revenue per user (ARPU)","category":"Customer","description":"recurring revenue per account","formula":"recurring revenue / number of active accounts","source":"CRM/Accounting"},
  {"id":44,"metric":"Customer expansion revenue","category":"Customer","description":"upsell and cross-sell revenue","formula":"revenue from upgrades/add-ons","source":"CRM/Accounting"},
  {"id":45,"metric":"Net promoter score (NPS)","category":"Customer","description":"loyalty and referral indicator","formula":"% promoters - % detractors","source":"Survey/Support"},
  {"id":46,"metric":"Customer satisfaction (CSAT)","category":"Customer","description":"satisfaction after interactions","formula":"mean survey score","source":"Support/Survey"},
  {"id":47,"metric":"Customer engagement (activity)","category":"Customer","description":"usage or engagement rate","formula":"active sessions or transactions per period","source":"Product analytics/CRM"},
  {"id":48,"metric":"Support response time","category":"Customer","description":"time to first reply to support requests","formula":"average time from ticket creation to first response","source":"Support"},
  {"id":49,"metric":"Support resolution time","category":"Customer","description":"average time to resolve tickets","formula":"closed time - open time","source":"Support"},
  {"id":50,"metric":"Customer segmentation (e.g., top 5 customers)","category":"Customer","description":"revenue concentration by customer","formula":"revenue per customer sorted descending","source":"Accounting/CRM"},
  {"id":51,"metric":"Website traffic (visits, unique visitors)","category":"Marketing","description":"number of site visits","formula":"count of sessions/unique users","source":"Web analytics"},
  {"id":52,"metric":"Traffic sources","category":"Marketing","description":"origin of visitors","formula":"distribution by channel (organic, paid, social, referral)","source":"Web analytics"},
  {"id":53,"metric":"Conversion rate","category":"Marketing","description":"visitors converting to leads/customers","formula":"conversions / visitors × 100","source":"Web analytics"},
  {"id":54,"metric":"Cost per lead (CPL)","category":"Marketing","description":"cost to generate a lead","formula":"marketing spend / number of leads","source":"Marketing"},
  {"id":55,"metric":"Marketing ROI","category":"Marketing","description":"return on marketing investment","formula":"(revenue from marketing - cost) / cost × 100","source":"Marketing"},
  {"id":56,"metric":"Email open rate","category":"Marketing","description":"email engagement indicator","formula":"opened emails / emails sent × 100","source":"Email platform"},
  {"id":57,"metric":"Email click-through rate (CTR)","category":"Marketing","description":"clicks within email","formula":"clicks / emails sent × 100","source":"Email platform"},
  {"id":58,"metric":"Social media engagement","category":"Marketing","description":"likes, shares, comments, follower growth","formula":"aggregated engagement metrics","source":"Social platforms"},
  {"id":59,"metric":"Bounce rate (website)","category":"Marketing","description":"% leaving without action","formula":"single-page sessions / total sessions","source":"Web analytics"},
  {"id":60,"metric":"Keyword rankings (SEO)","category":"Marketing","description":"search engine position for key terms","formula":"ranking position per keyword","source":"SEO tools"},
  {"id":61,"metric":"Lead quality score","category":"Marketing","description":"likelihood of a lead becoming a customer","formula":"ratio of leads that convert + sales feedback","source":"CRM/Marketing"},
  {"id":62,"metric":"Return on ad spend (ROAS)","category":"Marketing","description":"revenue per advertising dollar","formula":"revenue from ads / ad spend","source":"Marketing"},
  {"id":63,"metric":"Cost per click (CPC)","category":"Marketing","description":"cost per ad click","formula":"ad spend / clicks","source":"Marketing"},
  {"id":64,"metric":"Click-through rate (ads)","category":"Marketing","description":"ad engagement rate","formula":"clicks / impressions × 100","source":"Marketing"},
  {"id":65,"metric":"Landing page conversion rate","category":"Marketing","description":"effectiveness of landing pages","formula":"conversions / visitors × 100","source":"Web analytics"},
  {"id":66,"metric":"Inventory turnover","category":"Operations","description":"how fast stock is sold","formula":"COGS / average inventory","source":"Accounting"},
  {"id":67,"metric":"Days in inventory (DIO)","category":"Operations","description":"days inventory sits","formula":"(average inventory / COGS) × 365","source":"Accounting"},
  {"id":68,"metric":"Revenue per employee","category":"Operations","description":"productivity per worker","formula":"revenue / number of employees","source":"HR/Accounting"},
  {"id":69,"metric":"Payroll to revenue ratio","category":"Operations","description":"labor cost proportion","formula":"total payroll / revenue","source":"HR/Accounting"},
  {"id":70,"metric":"Operating expense ratio (OPEX)","category":"Operations","description":"overhead efficiency","formula":"operating expenses / revenue","source":"Accounting"},
  {"id":71,"metric":"Capacity utilization","category":"Operations","description":"production or service utilization rate","formula":"actual output / maximum capacity","source":"Operations"},
  {"id":72,"metric":"Average order fulfillment time","category":"Operations","description":"time to fulfill orders","formula":"time from order to delivery","source":"CRM/Operations"},
  {"id":73,"metric":"On-time delivery rate","category":"Operations","description":"percentage of orders delivered on time","formula":"on-time deliveries / total deliveries","source":"Operations"},
  {"id":74,"metric":"Inventory accuracy","category":"Operations","description":"correctness of inventory records","formula":"(system count - physical count) / physical count","source":"Operations"},
  {"id":75,"metric":"Project/job cost variance","category":"Operations","description":"difference between budgeted and actual cost","formula":"(actual cost - budget)/budget","source":"Operations/Accounting"},
  {"id":76,"metric":"Utilization rate (service)","category":"Operations","description":"billable vs. total hours","formula":"billable hours / total available hours","source":"HR"},
  {"id":77,"metric":"Employee turnover rate","category":"Operations","description":"staff attrition rate","formula":"(employees leaving / average number of employees) × 100","source":"HR"},
  {"id":78,"metric":"Employee satisfaction/engagement score","category":"Operations","description":"workplace morale","formula":"survey score or eNPS","source":"HR/Survey"},
  {"id":79,"metric":"Training cost per employee","category":"Operations","description":"investment in skills","formula":"total training spend / number of employees trained","source":"HR"},
  {"id":80,"metric":"Absenteeism rate","category":"Operations","description":"days lost to absence","formula":"total absence days / total available days","source":"HR"},
  {"id":81,"metric":"Monthly recurring revenue (MRR)","category":"Product","description":"recurring revenue per month","formula":"sum of subscription revenue in a month","source":"Billing/CRM"},
  {"id":82,"metric":"Annual recurring revenue (ARR)","category":"Product","description":"recurring revenue per year","formula":"MRR × 12","source":"Billing/CRM"},
  {"id":83,"metric":"Net new MRR","category":"Product","description":"new recurring revenue acquired","formula":"new MRR + expansion MRR - churned MRR","source":"Billing"},
  {"id":84,"metric":"Average revenue per user (ARPU)","category":"Product","description":"recurring revenue per customer","formula":"total recurring revenue / active customers","source":"Billing"},
  {"id":85,"metric":"Monthly active users (MAU)","category":"Product","description":"engagement of product","formula":"number of unique users active in month","source":"Product analytics"},
  {"id":86,"metric":"Daily active users (DAU)","category":"Product","description":"daily engagement","formula":"number of unique users active per day","source":"Product analytics"},
  {"id":87,"metric":"Activation rate","category":"Product","description":"sign-ups becoming active users","formula":"activated users / sign-ups","source":"Product analytics"},
  {"id":88,"metric":"Feature adoption rate","category":"Product","description":"usage of key features","formula":"users using feature / total users","source":"Product analytics"},
  {"id":89,"metric":"Churned MRR","category":"Product","description":"recurring revenue lost","formula":"MRR from churned customers","source":"Billing"},
  {"id":90,"metric":"Expansion MRR","category":"Product","description":"recurring revenue from upsells","formula":"additional MRR from existing customers","source":"Billing"},
  {"id":91,"metric":"Debt-to-equity ratio","category":"Risk","description":"leverage level","formula":"total debt / total equity","source":"Accounting"},
  {"id":92,"metric":"Interest coverage ratio","category":"Risk","description":"ability to pay interest","formula":"earnings before interest & tax / interest expense","source":"Accounting"},
  {"id":93,"metric":"Return on assets (ROA)","category":"Risk","description":"efficiency of asset use","formula":"net income / total assets","source":"Accounting"},
  {"id":94,"metric":"Return on equity (ROE)","category":"Risk","description":"return to shareholders","formula":"net income / shareholder equity","source":"Accounting"},
  {"id":95,"metric":"Asset turnover ratio","category":"Risk","description":"efficiency of asset use to generate revenue","formula":"revenue / average assets","source":"Accounting"},
  {"id":96,"metric":"Break-even point","category":"Risk","description":"sales level at zero profit","formula":"fixed costs / (price - variable cost per unit)","source":"Accounting"},
  {"id":97,"metric":"Budget vs. actual variance","category":"Risk","description":"variance between planned and actual results","formula":"(actual - budget) / budget","source":"Accounting"},
  {"id":98,"metric":"Credit utilization ratio","category":"Risk","description":"percentage of credit used","formula":"outstanding debt / credit limit","source":"Accounting"},
  {"id":99,"metric":"Tax liability to revenue ratio","category":"Risk","description":"tax burden intensity","formula":"total taxes / revenue","source":"Accounting"},
  {"id":100,"metric":"Forecast error (financial)","category":"Risk","description":"deviation of forecast from actual","formula":"(forecast - actual)/forecast","source":"Accounting/CRM"}
