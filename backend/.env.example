# ===============================
# BIQc Backend .env template (DEV)
# ===============================

# Core runtime
ENVIRONMENT=development
PRODUCTION=0
PORT=8001
WEBSITES_PORT=8001

# App URLs (DEV)
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8001
PUBLIC_FRONTEND_URL=http://localhost:3000
OAUTH_REDIRECT_BASE_URL=http://localhost:8001

# Auth / JWT (required)
JWT_SECRET_KEY=replace_with_strong_secret

# Supabase (DEV project)
SUPABASE_URL=https://your-dev-project.supabase.co
SUPABASE_ANON_KEY=replace_with_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=replace_with_supabase_service_role_key

# AI providers
OPENAI_API_KEY=replace_with_openai_key
GOOGLE_API_KEY=replace_with_google_ai_key
ANTHROPIC_API_KEY=replace_with_anthropic_key

# Google auth
GOOGLE_CLIENT_ID=replace_with_google_client_id
GOOGLE_CLIENT_SECRET=replace_with_google_client_secret

# Microsoft auth
AZURE_TENANT_ID=common
AZURE_TENANT_URL=https://login.microsoftonline.com/common
AZURE_CLIENT_ID=replace_with_azure_client_id
AZURE_CLIENT_SECRET=replace_with_azure_client_secret
AZURE_REDIRECT_URI=http://localhost:8001/api/auth/outlook/callback

# Email / notifications
RESEND_API_KEY=replace_with_resend_key
RESEND_FROM_EMAIL=noreply@yourdomain.com
BIQC_RESEND_FROM_EMAIL=noreply@yourdomain.com
BIQC_ADMIN_NOTIFICATION_EMAIL=ops@yourdomain.com

# Integrations
MERGE_API_KEY=replace_with_merge_key
MERGE_REDIRECT_URI=http://localhost:8001/api/integrations/merge/callback
SERPER_API_KEY=replace_with_serper_key

# CORS
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Redis (optional but recommended)
REDIS_URL=redis://localhost:6379/0

# Feature flags
SOUNDBOARD_V3_ENABLED=true
SOUNDBOARD_BOARDROOM_ORCH_ENABLED=true
BIQC_MASTER_ADMIN_EMAIL=andre@thestrategysquad.com.au
BIQC_INTERNAL_EMAIL_DOMAIN=biqc.ai

# Dev/QA bypass (OFF unless explicitly testing bypass)
DEV_BYPASS_AUTH=0
DEV_BYPASS_SECRET=replace_with_dev_bypass_secret
QA_BYPASS_AUTH=0
QA_BYPASS_SECRET=replace_with_qa_bypass_secret
QA_BYPASS_USER_ID=
QA_BYPASS_EMAIL=
QA_BYPASS_ROLE=admin
QA_BYPASS_TIER=starter
