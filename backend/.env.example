# ═══════════════════════════════════════════════════════════════
# BIQc Backend — Environment Variables Reference
# Copy to .env and fill in values. Variables marked [REQUIRED]
# will crash the server if missing. Others have sensible defaults.
# ═══════════════════════════════════════════════════════════════

# ─── Core Runtime ─────────────────────────────────────────────
ENVIRONMENT=development          # development | staging | production
PRODUCTION=0                     # 1 = production mode, 0 = dev
PORT=8001                        # HTTP port (Azure overrides via WEBSITES_PORT)

# ─── URLs ─────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
PUBLIC_FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8001
OAUTH_REDIRECT_BASE_URL=http://localhost:8001

# ─── Auth / JWT [REQUIRED] ───────────────────────────────────
JWT_SECRET_KEY=                  # [REQUIRED] Server will crash without this
BIQC_MASTER_ADMIN_EMAIL=        # [REQUIRED in production] Super admin email

# ─── Supabase [REQUIRED for data] ────────────────────────────
SUPABASE_URL=https://xdqwclwsgksbapxmwjaq.supabase.co
SUPABASE_ANON_KEY=               # From Supabase Dashboard → Settings → API
SUPABASE_SERVICE_ROLE_KEY=       # From Supabase Dashboard → Settings → API (service_role)

# ─── AI Providers ────────────────────────────────────────────
OPENAI_API_KEY=                  # GPT-4o for intelligence engines
ANTHROPIC_API_KEY=               # Claude for narrative synthesis
GOOGLE_API_KEY=                  # Gemini (optional)

# AI model overrides (optional — code has defaults)
# ANTHROPIC_MODEL_OPUS=claude-opus-4-0-20250514
# ANTHROPIC_MODEL_SONNET=claude-sonnet-4-20250514
# OPENAI_MODEL_DEEP=gpt-4o
# OPENAI_MODEL_NORMAL=gpt-4o-mini
# GEMINI_MODEL_PRO=gemini-pro

# ─── Google OAuth ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Microsoft OAuth ─────────────────────────────────────────
AZURE_TENANT_ID=common
AZURE_TENANT_URL=https://login.microsoftonline.com/common
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_REDIRECT_URI=http://localhost:8001/api/auth/outlook/callback

# ─── Email / Notifications ───────────────────────────────────
RESEND_API_KEY=                  # Resend.com for transactional email
RESEND_FROM_EMAIL=noreply@biqc.ai
BIQC_RESEND_FROM_EMAIL=noreply@biqc.ai
BIQC_ADMIN_NOTIFICATION_EMAIL=ops@biqc.ai

# ─── Integrations ────────────────────────────────────────────
MERGE_API_KEY=                   # Merge.dev unified API
MERGE_WEBHOOK_SECRET=
SERPER_API_KEY=                  # Serper.dev for web search (optional)

# ─── Payments ────────────────────────────────────────────────
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Redis / Cache ───────────────────────────────────────────
REDIS_URL=                       # redis://host:6379 (optional — graceful fallback)
# REDIS_USE_MANAGED_IDENTITY=0
# REDIS_MANAGED_IDENTITY_CLIENT_ID=
# REDIS_AAD_USERNAME=

# ─── CORS ────────────────────────────────────────────────────
CORS_ALLOW_ORIGINS=http://localhost:3000,https://biqc.ai,https://biqc-web-dev.azurewebsites.net

# ─── Feature Flags (env var fallbacks) ───────────────────────
FEATURE_MERGE_WEBHOOK_ENABLED=false
SOUNDBOARD_V3_ENABLED=true
WARROOM_STREAMING_V2_ENABLED=true
ENRICHMENT_WORKER_ENABLED=true
# SOUNDBOARD_BOARDROOM_ORCH_ENABLED=false

# ─── Performance Tuning (optional) ──────────────────────────
# ASK_BIQC_LATENCY_SLO_MS_DEFAULT=12000
# ASK_BIQC_LATENCY_SLO_MS_DEEP=30000
# SOUNDBOARD_CONTEXT_MESSAGES_LIMIT=20
# SOUNDBOARD_HISTORY_LIMIT=50
# SOUNDBOARD_SIGNAL_REFRESH_INTERVAL_MINUTES=5
# INTEGRATION_STATUS_CACHE_TTL_SECONDS=300
# MERGE_EMISSION_PAGE_SIZE=200
# MERGE_EMISSION_MAX_PAGES=5

# ─── Dev/QA Bypass (NEVER set in production) ────────────────
# DEV_BYPASS_AUTH=0
# DEV_BYPASS_SECRET=
# QA_BYPASS_AUTH=0
# QA_BYPASS_SECRET=
# QA_BYPASS_EMAIL=
# QA_BYPASS_ROLE=
# QA_BYPASS_TIER=
# QA_BYPASS_USER_ID=

# ─── Test Accounts (CI only) ────────────────────────────────
# TEST_LOGIN_EMAIL=
# TEST_LOGIN_PASSWORD=
# E2E_TEST_EMAIL=
# E2E_TEST_PASSWORD=
