{
  "edge_functions": [
    {
      "name": "calibration-psych",
      "purpose": "AI-driven persona calibration conversation — determines operator communication preferences",
      "tables_read": ["user_operator_profile", "business_profiles"],
      "tables_written": ["user_operator_profile"],
      "external_apis": ["OpenAI"],
      "uses_openai": "Y",
      "returns": "prose",
      "triggered_by": "route: /calibration (frontend CalibrationAdvisor.js)"
    },
    {
      "name": "gmail_prod",
      "purpose": "Gmail OAuth authentication and email fetching via Google API",
      "tables_read": ["email_connections"],
      "tables_written": ["email_connections"],
      "external_apis": ["Google Gmail API"],
      "uses_openai": "N",
      "returns": "structured JSON",
      "triggered_by": "route: /integrations, /connect-email (Gmail connect flow)"
    },
    {
      "name": "outlook-auth",
      "purpose": "Microsoft Outlook OAuth authentication flow",
      "tables_read": ["outlook_oauth_tokens"],
      "tables_written": ["outlook_oauth_tokens", "email_connections"],
      "external_apis": ["Microsoft Graph API"],
      "uses_openai": "N",
      "returns": "redirect",
      "triggered_by": "route: /connect-email, /integrations (Outlook connect flow)"
    },
    {
      "name": "email_priority",
      "purpose": "AI-powered email priority analysis and categorization",
      "tables_read": ["outlook_emails", "email_connections"],
      "tables_written": [],
      "external_apis": ["OpenAI"],
      "uses_openai": "Y",
      "returns": "structured JSON",
      "triggered_by": "route: /email-inbox (EmailInbox.js)"
    },
    {
      "name": "intelligence-snapshot",
      "purpose": "Generates intelligence snapshot from integrated data sources for advisor context",
      "tables_read": ["observation_events", "watchtower_insights", "business_profiles", "integration_accounts"],
      "tables_written": ["intelligence_snapshots"],
      "external_apis": ["OpenAI"],
      "uses_openai": "Y",
      "returns": "structured JSON",
      "triggered_by": "backend: get_ai_response() helper function (called by multiple advisor routes)"
    }
  ],
