# ===============================
# BIQc Frontend .env template (DEV)
# ===============================

# API target (CRITICAL)
REACT_APP_BACKEND_URL=http://localhost:8001

# Supabase (DEV project)
REACT_APP_SUPABASE_URL=https://your-dev-project.supabase.co
REACT_APP_SUPABASE_ANON_KEY=replace_with_supabase_anon_key

# OAuth
REACT_APP_GOOGLE_CLIENT_ID=replace_with_google_client_id
REACT_APP_AZURE_CLIENT_ID=replace_with_azure_client_id
REACT_APP_BIQC_MASTER_ADMIN_EMAIL=andre@thestrategysquad.com.au

# Preview/feature toggles
REACT_APP_ENABLE_PREVIEW_ROUTES=true

# Dev bypass (only for local debugging)
REACT_APP_DEV_BYPASS_AUTH=0
REACT_APP_DEV_BYPASS_SECRET=replace_with_dev_bypass_secret

# reCAPTCHA
REACT_APP_RECAPTCHA_SITE_KEY=replace_with_recaptcha_site_key
REACT_APP_RECAPTCHA_MODE=google
REACT_APP_RECAPTCHA_PROVIDER=google
REACT_APP_RECAPTCHA_STRICT=true
REACT_APP_RECAPTCHA_DISABLED=false
REACT_APP_RECAPTCHA_DEBUG=false

# Stripe
REACT_APP_STRIPE_STARTER_PRICE_ID=replace_with_stripe_starter_price_id
