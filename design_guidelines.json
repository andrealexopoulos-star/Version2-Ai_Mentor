{
  "project_name": "BIQc Landing Page Redesign",
  "design_philosophy": {
    "identity": "E1: Anti-AI Designer",
    "core_principles": [
      "Fusion over Imitation: Swiss Style + Tactical SaaS",
      "Emotion First: Sovereign = Trust, Intelligence = Clarity",
      "Content is King: Directed storytelling",
      "Zoom In: Focus on data details",
      "Negative Space: Luxurious breathing room"
    ],
    "anti_patterns": [
      "No generic 'Inter' for headings",
      "No center-aligned everything",
      "No excessive gradients",
      "No 'default' Shadcn look"
    ]
  },
  "typography": {
    "font_family": {
      "headings": "Outfit, sans-serif",
      "body": "DM Sans, sans-serif",
      "mono": "JetBrains Mono, monospace"
    },
    "scale": {
      "h1": "text-5xl md:text-7xl font-bold tracking-tight leading-[1.1]",
      "h2": "text-4xl md:text-5xl font-semibold tracking-tight",
      "h3": "text-2xl md:text-3xl font-semibold",
      "body_lg": "text-lg md:text-xl leading-relaxed text-slate-600",
      "body_base": "text-base leading-relaxed text-slate-600",
      "caption": "text-xs font-mono uppercase tracking-widest text-slate-500"
    }
  },
  "colors": {
    "palette": {
      "primary": {
        "base": "#0f172a",
        "hover": "#1e293b",
        "foreground": "#ffffff"
      },
      "accent": {
        "blue": "#2563eb",
        "blue_light": "#dbeafe",
        "emerald": "#059669",
        "emerald_light": "#d1fae5",
        "amber": "#d97706",
        "rose": "#e11d48"
      },
      "neutral": {
        "white": "#ffffff",
        "slate_50": "#f8fafc",
        "slate_100": "#f1f5f9",
        "slate_200": "#e2e8f0",
        "slate_900": "#0f172a"
      }
    },
    "usage": {
      "background": "bg-slate-50",
      "surface": "bg-white",
      "text_main": "text-slate-900",
      "text_muted": "text-slate-600",
      "border": "border-slate-200"
    }
  },
  "components": {
    "buttons": {
      "primary": "bg-slate-900 text-white hover:bg-slate-800 rounded-lg px-8 py-4 font-semibold shadow-lg shadow-slate-900/20 transition-all hover:-translate-y-0.5",
      "secondary": "bg-white text-slate-900 border border-slate-200 hover:bg-slate-50 rounded-lg px-8 py-4 font-medium transition-all",
      "ghost": "text-slate-600 hover:text-slate-900 hover:bg-slate-100 rounded-lg px-4 py-2 transition-all"
    },
    "cards": {
      "base": "bg-white border border-slate-200 rounded-2xl p-8 shadow-sm hover:shadow-md transition-all",
      "feature": "bg-white border border-slate-100 rounded-3xl p-8 shadow-xl shadow-slate-200/50 hover:shadow-2xl hover:shadow-slate-200/60 transition-all duration-300",
      "pricing_highlight": "bg-slate-900 text-white rounded-3xl p-8 shadow-2xl shadow-slate-900/30 relative overflow-hidden"
    },
    "badges": {
      "base": "inline-flex items-center px-3 py-1 rounded-full text-xs font-medium font-mono uppercase tracking-wider",
      "blue": "bg-blue-50 text-blue-700 border border-blue-100",
      "emerald": "bg-emerald-50 text-emerald-700 border border-emerald-100"
    }
  },
  "layout_strategies": {
    "spacing": {
      "section_y": "py-24 md:py-32",
      "container_x": "px-6 md:px-12 lg:px-20",
      "element_gap": "gap-8 md:gap-12"
    },
    "grids": {
      "hero": "grid grid-cols-1 lg:grid-cols-2 gap-16 items-center",
      "bento": "grid grid-cols-1 md:grid-cols-3 gap-6",
      "features": "grid grid-cols-1 md:grid-cols-2 gap-8"
    }
  },
  "motion": {
    "library": "framer-motion",
    "variants": {
      "fadeInUp": {
        "initial": { "opacity": 0, "y": 20 },
        "whileInView": { "opacity": 1, "y": 0 },
        "viewport": { "once": true },
        "transition": { "duration": 0.5, "ease": "easeOut" }
      },
      "stagger": {
        "initial": "hidden",
        "animate": "visible",
        "variants": {
          "visible": { "transition": { "staggerChildren": 0.1 } }
        }
      }
    }
  },
  "sections_breakdown": [
    {
      "name": "Navbar",
      "type": "sticky",
      "style": "glassmorphism",
      "elements": ["Logo (BIQc)", "Trust Link", "Login", "Start Free (Primary CTA)"]
    },
    {
      "name": "Hero",
      "layout": "split",
      "left": ["Eyebrow: Sovereign Intelligence", "Rotating Headline", "Subhead", "CTA Group", "Trust Badge"],
      "right": ["Live Intelligence Panel (Mocked UI)", "Floating Elements"],
      "fix": "Ensure right panel render"
    },
    {
      "name": "Trust Strip",
      "layout": "full-width",
      "style": "marquee",
      "content": "Marquee of integration logos"
    },
    {
      "name": "Comparison",
      "title": "Dashboards vs Agents",
      "interaction": "Toggle Switch",
      "visual": "Side-by-side comparison or Cross-fade based on toggle"
    },
    {
      "name": "Features",
      "layout": "Bento Grid",
      "cards": ["The Boardroom", "Strategic Console", "SoundBoard", "BIQc Insights"]
    },
    {
      "name": "WIIFM",
      "layout": "3-Col Grid",
      "cards": ["Time Reclaimed", "Profit Leaks Plugged", "SOP Compliance"]
    },
    {
      "name": "Pricing",
      "layout": "3-Col Grid",
      "highlight": "The Strategist (Middle)"
    },
    {
      "name": "Sovereignty",
      "style": "Trust Badge/Banner",
      "content": "Australian Data Sovereignty"
    },
    {
      "name": "Footer",
      "style": "Minimal",
      "content": "Copyright, Disclaimer"
    }
  ],
  "image_urls": {
     "hero_bg": "generated-gradient-mesh",
     "logos": [
       "https://upload.wikimedia.org/wikipedia/commons/thumb/1/15/Xero_software_logo.svg/2560px-Xero_software_logo.svg.png",
       "https://upload.wikimedia.org/wikipedia/commons/f/f9/Salesforce.com_logo.svg",
       "https://upload.wikimedia.org/wikipedia/commons/thumb/3/3f/HubSpot_Logo.svg/2560px-HubSpot_Logo.svg.png",
       "https://upload.wikimedia.org/wikipedia/commons/thumb/b/ba/Stripe_Logo%2C_revised_2016.svg/2560px-Stripe_Logo%2C_revised_2016.svg.png",
       "https://upload.wikimedia.org/wikipedia/commons/d/d5/Slack_icon_2019.svg",
       "https://upload.wikimedia.org/wikipedia/commons/0/08/Microsoft_Office_365_%282019%E2%80%93present%29.svg",
       "https://upload.wikimedia.org/wikipedia/commons/5/53/Google_%22G%22_Logo.svg"
     ]
  },
  "instructions_to_main_agent": "Refactor LandingIntelligent.js to use Tailwind classes instead of inline styles. Use Shadcn components for Buttons and Cards where possible, but customize them to match the E1 aesthetic. Ensure the Hero Right Panel is visible by fixing the animation logic (remove initial='hidden' if it blocks rendering). Preserve all existing text content and logic (toggle, etc.). Use 'Outfit' for headings and 'DM Sans' for body."
}
